@model Midix.ViewModel.StaffViewModel
@using Midix.Models

@{
    ViewData["Title"] = "Staff Management";
    ViewData["ActiveTab"] = "staff";
}

@section Styles {
    <style>
        #navbar {
            display: none;
        }

        body {
            background: var(--gray-50);
        }

        .btn-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 32px;
            height: 32px;
            border-radius: var(--radius-sm);
            border: none;
            cursor: pointer;
            font-size: 13px;
            text-decoration: none;
            transition: var(--transition);
        }

        .btn-edit {
            background: var(--blue-light);
            color: var(--blue);
        }

            .btn-edit:hover {
                background: var(--blue);
                color: #fff;
            }

        .btn-deactivate {
            background: #fff0f0;
            color: #e53e3e;
        }

            .btn-deactivate:hover {
                background: #e53e3e;
                color: #fff;
            }

        .btn-activate {
            background: #f0fff4;
            color: #38a169;
        }

            .btn-activate:hover {
                background: #38a169;
                color: #fff;
            }

        .pagination-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .75rem 1rem;
            border-top: 1px solid var(--gray-100);
            font-size: .875rem;
            color: var(--gray-500);
            flex-wrap: wrap;
            gap: .5rem;
        }

        .pagination-controls {
            display: flex;
            gap: .4rem;
            align-items: center;
        }

        .page-btn {
            padding: .3rem .7rem;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-sm);
            background: #fff;
            color: var(--gray-700);
            text-decoration: none;
            font-size: .8rem;
            transition: .15s;
        }

            .page-btn:hover {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
            }

            .page-btn.disabled {
                opacity: .4;
                cursor: not-allowed;
                pointer-events: none;
            }

            .page-btn.current {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
                font-weight: 700;
            }

        .avatar-mini-img {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            object-fit: cover;
        }
    </style>
}

<div class="dashboard-layout">

    @await Html.PartialAsync("_AdminSidebar")

    <main class="dashboard-main">

        <div class="dashboard-header admin-header">
            <div>
                <h1>Staff Management</h1>
                <p>Manage doctors and admin accounts</p>
            </div>
            <div class="header-actions">
                <span class="date-badge">
                    <i class="fas fa-calendar"></i> @DateTime.Now.ToString("MMM dd, yyyy")
                </span>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background:var(--green-light);color:var(--green);padding:12px 20px;border-radius:var(--radius-sm);margin-bottom:16px;">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }

        <div class="card-header-row">
            <h2>Doctors</h2>
            <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                <a asp-controller="AdminDashboard" asp-action="AllUsers"
                   class="btn btn-outline" style="border-color:var(--teal,#319795);color:var(--teal,#319795);">
                    <i class="fas fa-users"></i> View All Users
                </a>
                <a asp-controller="AdminDashboard" asp-action="AddAdmin"
                   class="btn btn-outline" style="border-color:var(--purple,#805ad5);color:var(--purple,#805ad5);">
                    <i class="fas fa-user-shield"></i> Add Admin
                </a>
                <a asp-controller="AdminDashboard" asp-action="AddDoctor" class="btn btn-orange">
                    <i class="fas fa-plus"></i> Add New Doctor
                </a>
            </div>
        </div>

        <div class="dash-card">
            <div class="appointments-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>Unique Patients</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Doctors)
                        {
                            <tr>
                                <td>
                                    <div class="table-doctor">

                                        @if (!string.IsNullOrEmpty(d.Picture))
                                        {
                                            <img src="~/images/users/@d.Picture"
                                                 asp-append-version="true"
                                                 class="avatar-mini-img"
                                                 alt="@d.FullName" />
                                        }
                                        else
                                        {
                                            <div class="avatar-mini">
                                                @d.Initials
                                            </div>
                                        }

                                        @d.FullName

                                    </div>
                                </td>
                                <td>@d.Specialization</td>
                                <td>@d.PatientCount</td>
                                <td>
                                    @if (d.IsActive)
                                    {
                                        <span class="badge badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-inactive">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:.5rem;align-items:center;">
                                        <a asp-controller="AdminDashboard" asp-action="EditDoctor"
                                           asp-route-userId="@d.UserId"
                                           class="btn-icon btn-edit" title="Edit Doctor">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (d.IsActive)
                                        {
                                            <a asp-controller="AdminDashboard" asp-action="DeactivateDoctor"
                                               asp-route-userId="@d.UserId"
                                               class="btn-icon btn-deactivate" title="Deactivate Doctor">
                                                <i class="fas fa-user-slash"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <form asp-controller="AdminDashboard" asp-action="ActivateDoctor"
                                                  method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@d.UserId" />
                                                <button type="submit" class="btn-icon btn-activate" title="Activate Doctor">
                                                    <i class="fas fa-user-check"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Doctors.Any())
                        {
                            <tr><td colspan="5" style="text-align:center;color:var(--gray-400);padding:2rem;">No doctors found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                var p = Model.Pagination;
                int start = Math.Max(1, p.CurrentPage - 2);
                int end = Math.Min(p.TotalPages, p.CurrentPage + 2);
            }
            @if (p.TotalPages > 1)
            {
                <div class="pagination-bar">
                    <span>Showing page @p.CurrentPage of @p.TotalPages (@p.TotalItems doctors)</span>
                    <div class="pagination-controls">
                        <a asp-action="Staff" asp-route-page="1" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-double-left"></i></a>
                        <a asp-action="Staff" asp-route-page="@(p.CurrentPage - 1)" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-left"></i></a>
                        @for (int pg = start; pg <= end; pg++)
                        {
                            <a asp-action="Staff" asp-route-page="@pg" asp-route-pageSize="@p.PageSize"
                               class="page-btn @(pg == p.CurrentPage ? "current" : "")">@pg</a>
                        }
                        <a asp-action="Staff" asp-route-page="@(p.CurrentPage + 1)" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasNext ? "disabled" : "")"><i class="fas fa-angle-right"></i></a>
                        <a asp-action="Staff" asp-route-page="@p.TotalPages" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasNext ? "disabled" : "")"><i class="fas fa-angle-double-right"></i></a>
                    </div>
                </div>
            }
        </div>

    </main>
</div>
