@model Midix.ViewModel.FinancialViewModel
@using Midix.Models
@using Midix.Enums

@{
    ViewData["Title"] = "Financial Reports";
    ViewData["ActiveTab"] = "financial";
}

@section Styles {
    <style>
        #navbar {
            display: none;
        }

        body {
            background: var(--gray-50);
        }

        .pagination-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .75rem 1rem;
            border-top: 1px solid var(--gray-100);
            font-size: .875rem;
            color: var(--gray-500);
            flex-wrap: wrap;
            gap: .5rem;
        }

        .pagination-controls {
            display: flex;
            gap: .4rem;
            align-items: center;
        }

        .page-btn {
            padding: .3rem .7rem;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-sm);
            background: #fff;
            color: var(--gray-700);
            text-decoration: none;
            font-size: .8rem;
            transition: .15s;
        }

            .page-btn:hover {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
            }

            .page-btn.disabled {
                opacity: .4;
                cursor: not-allowed;
                pointer-events: none;
            }

            .page-btn.current {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
                font-weight: 700;
            }
    </style>
}

<div class="dashboard-layout">

    @await Html.PartialAsync("_AdminSidebar")

    <main class="dashboard-main">

        <div class="dashboard-header admin-header">
            <div>
                <h1>Financial Reports</h1>
                <p>Revenue, payments, and transaction history</p>
            </div>
            <div class="header-actions">
                <span class="date-badge">
                    <i class="fas fa-calendar"></i> @DateTime.Now.ToString("MMM dd, yyyy")
                </span>
            </div>
        </div>

        <div class="stats-row">
            <div class="stat-card green">
                <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
                <div class="stat-info">
                    <span class="stat-value">$@((Model.OnlinePayments + Model.CashPayments).ToString("N0"))</span>
                    <span class="stat-label">Total Collected (This Month)</span>
                </div>
            </div>
            <div class="stat-card blue">
                <div class="stat-icon"><i class="fas fa-credit-card"></i></div>
                <div class="stat-info">
                    <span class="stat-value">$@Model.OnlinePayments.ToString("N0")</span>
                    <span class="stat-label">Online / Card Payments</span>
                </div>
            </div>
            <div class="stat-card orange">
                <div class="stat-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="stat-info">
                    <span class="stat-value">$@Model.CashPayments.ToString("N0")</span>
                    <span class="stat-label">Cash Payments</span>
                </div>
            </div>
            <div class="stat-card purple">
                <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                <div class="stat-info">
                    <span class="stat-value">$@Model.PendingPayments.ToString("N0")</span>
                    <span class="stat-label">Pending</span>
                </div>
            </div>
        </div>

        <div class="dash-card">
            <div class="card-header">
                <h3>Transaction History</h3>
            </div>
            <div class="appointments-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Transaction ID</th>
                            <th>Patient</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Transactions)
                        {
                            var txBadge = t.Status == PaymentStatus.Paid ? "badge-paid"
                            : t.Status == PaymentStatus.Failed ? "badge-danger"
                            : "badge-pending";
                            var methodIcon = t.Method == PaymentMethod.Cash ? "fa-money-bill-wave" : "fa-credit-card";
                            <tr>
                                <td><code>TXN-@t.Id.ToString("D4")</code></td>
                                <td>@t.PatientName</td>
                                <td><strong>$@t.Amount.ToString("0.00")</strong></td>
                                <td><i class="fas @methodIcon"></i> @t.Method</td>
                                <td>@t.Date.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge @txBadge">@t.Status</span></td>
                            </tr>
                        }
                        @if (!Model.Transactions.Any())
                        {
                            <tr><td colspan="6" style="text-align:center;color:var(--gray-400);padding:2rem;">No transactions found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                var p = Model.Pagination;
                int start = Math.Max(1, p.CurrentPage - 2);
                int end = Math.Min(p.TotalPages, p.CurrentPage + 2);
            }
            @if (p.TotalPages > 1)
            {
                <div class="pagination-bar">
                    <span>Showing page @p.CurrentPage of @p.TotalPages (@p.TotalItems transactions)</span>
                    <div class="pagination-controls">
                        <a asp-action="Financial" asp-route-page="1" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-double-left"></i></a>
                        <a asp-action="Financial" asp-route-page="@(p.CurrentPage - 1)" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-left"></i></a>
                        @for (int pg = start; pg <= end; pg++)
                        {
                            <a asp-action="Financial" asp-route-page="@pg" asp-route-pageSize="@p.PageSize"
                               class="page-btn @(pg == p.CurrentPage ? "current" : "")">@pg</a>
                        }
                        <a asp-action="Financial" asp-route-page="@(p.CurrentPage + 1)" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasNext ? "disabled" : "")"><i class="fas fa-angle-right"></i></a>
                        <a asp-action="Financial" asp-route-page="@p.TotalPages" asp-route-pageSize="@p.PageSize"
                           class="page-btn @(!p.HasNext ? "disabled" : "")"><i class="fas fa-angle-double-right"></i></a>
                    </div>
                </div>
            }
        </div>

    </main>
</div>
