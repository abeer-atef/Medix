@model Midix.ViewModel.DoctorReviewsViewModel

@{
    ViewData["Title"] = "Doctor Reviews";
    ViewData["UsersTab"] = "doctors";
}

@section Styles {
    <link rel="stylesheet" href="~/css/users-dashboard.css" />
}

<div class="page-header">
    <div class="header-content">
        <div class="header-icon">
            <i class="fas fa-star"></i>
        </div>

        <div>
            <h1>@Model.DoctorName</h1>
            <p class="page-subtitle">
                Manage Doctor Reviews
            </p>
        </div>
    </div>

    <a asp-action="AllDoctors" class="btn-dashboard">
        <i class="fas fa-arrow-left"></i>
        Back
    </a>
</div>

<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-label">Average Rating</div>
        <div class="stat-number text-warning">
            ⭐ @Model.AverageRate.ToString("0.0")
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total Reviews</div>
        <div class="stat-number">
            @Model.TotalReviews
        </div>
    </div>

</div>

@if (!Model.Reviews.Any())
{
    <div class="dash-card text-center">

        <i class="fas fa-comment-slash empty-icon"></i>

        <h3>No Reviews Yet</h3>

        <p class="text-muted">
            This doctor doesn't have any reviews.
        </p>

    </div>
}
else
{
    <div class="reviews-grid">

        @foreach (var review in Model.Reviews)
        {
            <div class="review-card">

                <div class="review-header">

                    <div>
                        <h5>@review.PatientName</h5>

                        <span class="review-date">
                            @review.CreatedAt.ToString("dd MMM yyyy")
                        </span>
                    </div>

                    <div class="review-rate">

                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= review.Rate)
                            {
                                <i class="fas fa-star"></i>
                            }
                            else
                            {
                                <i class="far fa-star"></i>
                            }
                        }

                    </div>

                </div>

                <div class="review-comment">

                    @if (string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <span class="text-muted">
                            No comment provided.
                        </span>
                    }
                    else
                    {
                        @review.Comment
                    }

                </div>

                <div class="review-footer">

                    <button type="button"
                            class="delete-btn"
                            onclick="openDeleteModal(@review.RatingId,'@Model.DoctorId')">

                        <i class="fas fa-trash-alt"></i>
                        Delete Review

                    </button>

                </div>

            </div>
        }

    </div>
}

<!-- Delete Modal -->

<div id="deleteModal" class="modal-overlay">

    <div class="modal-box">

        <i class="fas fa-exclamation-triangle warning-icon"></i>

        <h3>Delete Review?</h3>

        <p>
            This action cannot be undone.
        </p>

        <form asp-action="DeleteReview" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   id="ratingId"
                   name="ratingId" />

            <input type="hidden"
                   id="doctorId"
                   name="doctorId" />

            <div class="modal-buttons">

                <button type="button"
                        class="btn btn-secondary"
                        onclick="closeDeleteModal()">
                    Cancel
                </button>

                <button type="submit"
                        class="btn btn-danger">
                    Delete
                </button>

            </div>

        </form>

    </div>

</div>


@section Scripts {

    <script>

        function openDeleteModal(ratingId, doctorId) {

            document.getElementById("ratingId").value = ratingId;
            document.getElementById("doctorId").value = doctorId;

            document.getElementById("deleteModal").style.display = "flex";
        }

        function closeDeleteModal() {

            document.getElementById("deleteModal").style.display = "none";
        }

        window.onclick = function (event) {

            if (event.target == document.getElementById("deleteModal")) {

                closeDeleteModal();
            }
        }

    </script>

}

<style>

    .reviews-grid {
        display: grid;
        gap: 20px;
        margin-top: 25px;
    }

    .review-card {
        background: #fff;
        border-radius: 16px;
        padding: 22px;
        border: 1px solid #edf0f5;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
        transition: .3s;
    }

        .review-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 35px rgba(0,0,0,.08);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 18px;
    }

        .review-header h5 {
            margin: 0;
            font-weight: 700;
        }

    .review-date {
        color: #8b8b8b;
        font-size: 13px;
    }

    .review-rate {
        color: #ffc107;
        font-size: 19px;
    }

    .review-comment {
        background: #f7f8fc;
        padding: 18px;
        border-radius: 10px;
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .review-footer {
        display: flex;
        justify-content: flex-end;
    }

    .delete-btn {
        border: none;
        background: #dc3545;
        color: #fff;
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: .3s;
    }

        .delete-btn:hover {
            background: #bb2d3b;
        }

    .empty-icon {
        font-size: 60px;
        color: #d1d1d1;
        margin-bottom: 15px;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        width: 420px;
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
    }

    .warning-icon {
        font-size: 60px;
        color: #f39c12;
        margin-bottom: 15px;
    }

    .modal-buttons {
        margin-top: 25px;
        display: flex;
        justify-content: center;
        gap: 15px;
    }

    .cancel-btn {
        border: none;
        background: #6c757d;
        color: #fff;
        padding: 10px 22px;
        border-radius: 10px;
        cursor: pointer;
    }

    .confirm-btn {
        border: none;
        background: #dc3545;
        color: #fff;
        padding: 10px 22px;
        border-radius: 10px;
        cursor: pointer;
    }

</style>