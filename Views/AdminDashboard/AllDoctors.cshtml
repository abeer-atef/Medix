@model Midix.ViewModel.AllUsersViewModel

@{
    ViewData["Title"] = "Doctors";
    ViewData["UsersTab"] = "doctors";
}

@section Styles {
    <link rel="stylesheet" href="~/css/users-dashboard.css" />
}

<div class="page-header">
    <div class="header-content">
        <div class="header-icon">
            <i class="fas fa-user-md"></i>
        </div>
        <div>
            <h1>All Doctors</h1>
            <p class="page-subtitle">
                Manage doctors and monitor patient activity.
            </p>
        </div>
    </div>

    <a asp-controller="AdminDashboard" asp-action="Index" class="btn-dashboard">
        <i class="fas fa-arrow-left"></i> Dashboard
    </a>
</div>

@await Html.PartialAsync("_UsersTabsNav")

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total Doctors</div>
        <div class="stat-number">
            @Model.DoctorsPagination.TotalItems
        </div>
    </div>
</div>

<div class="dash-card">
    <div class="appointments-table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Specialty</th>
                    <th>Unique Patients</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th>Reviews</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Doctors)
                {
                    <tr>
                        <td>
                            <div class="user-cell">

                                @if (!string.IsNullOrEmpty(d.Picture))
                                {
                                    <img src="~/images/users/@d.Picture"
                                         class="avatar-mini"
                                         style="width:40px;
                                            height:40px;
                                            border-radius:50%;
                                            object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="avatar-mini avatar-doctor">
                                        @d.Initials
                                    </div>
                                }

                                @d.FullName

                            </div>
                        </td>

                        <td>@d.Specialization</td>

                        <td>
                            <span class="counter-badge">@d.PatientCount</span>
                        </td>

                        <!-- Rating -->
                        <td>
                            <div class="rating-box">

                                <div class="rating-stars">
                                    <i class="fas fa-star"></i>
                                    <span>@d.AverageRate.ToString("0.0")</span>
                                </div>

                                <span class="review-count">
                                    @d.TotalReviews Review@(d.TotalReviews == 1 ? "" : "s")
                                </span>

                            </div>
                        </td>

                        <!-- Status -->
                        <td>
                            @if (d.IsActive)
                            {
                                <span class="badge badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-inactive">Inactive</span>
                            }
                        </td>

                        <!-- View Reviews -->
                        <td>

                            <a asp-action="DoctorReviews"
                               asp-route-doctorId="@d.UserId"
                               class="review-btn">

                                <i class="fas fa-comments"></i>
                                Reviews

                            </a>

                        </td>

                    </tr>
                }

                @if (!Model.Doctors.Any())
                {
                    <tr>
                        <td colspan="6"
                            style="text-align:center;color:var(--gray-400);padding:2rem;">
                            No doctors found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @{
        var dp = Model.DoctorsPagination;
        int start = Math.Max(1, dp.CurrentPage - 2);
        int end = Math.Min(dp.TotalPages, dp.CurrentPage + 2);
    }
    @if (dp.TotalPages > 1)
    {
        <div class="pagination-bar">
            <span>Page @dp.CurrentPage of @dp.TotalPages (@dp.TotalItems doctors)</span>
            <div class="pagination-controls">
                <a asp-action="AllDoctors" asp-route-page="1" asp-route-pageSize="@dp.PageSize" class="page-btn @(!dp.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-double-left"></i></a>
                <a asp-action="AllDoctors" asp-route-page="@(dp.CurrentPage - 1)" asp-route-pageSize="@dp.PageSize" class="page-btn @(!dp.HasPrevious ? "disabled" : "")"><i class="fas fa-angle-left"></i></a>
                @for (int pg = start; pg <= end; pg++)
                {
                    <a asp-action="AllDoctors" asp-route-page="@pg" asp-route-pageSize="@dp.PageSize" class="page-btn @(pg == dp.CurrentPage ? "current" : "")">@pg</a>
                }
                <a asp-action="AllDoctors" asp-route-page="@(dp.CurrentPage + 1)" asp-route-pageSize="@dp.PageSize" class="page-btn @(!dp.HasNext ? "disabled" : "")"><i class="fas fa-angle-right"></i></a>
                <a asp-action="AllDoctors" asp-route-page="@dp.TotalPages" asp-route-pageSize="@dp.PageSize" class="page-btn @(!dp.HasNext ? "disabled" : "")"><i class="fas fa-angle-double-right"></i></a>
            </div>
        </div>
    }
</div>
<style>

    .rating-box {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .rating-stars {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #f5b301;
        font-weight: 700;
        font-size: 15px;
    }

    .review-count {
        font-size: 12px;
        color: #8a8a8a;
    }

    .review-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 15px;
        border-radius: 10px;
        background: #4f46e5;
        color: #fff;
        text-decoration: none;
        transition: .3s;
        font-size: 14px;
        font-weight: 600;
    }

        .review-btn:hover {
            background: #3730a3;
            color: white;
            text-decoration: none;
            transform: translateY(-2px);
        }

</style>