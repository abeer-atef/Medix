@model Midix.ViewModel.DoctorReviewsViewModel

@{
    ViewData["Title"] = "My Reviews";
    ViewData["ActiveTab"] = "reviews";
}

@section Styles {
    <link rel="stylesheet" href="~/css/users-dashboard.css" />
}

<div class="page-header">
    <div class="header-content">
        <div class="header-icon">
            <i class="fas fa-star"></i>
        </div>

        <div>
            <h1>My Reviews</h1>
            <p class="page-subtitle">
                See what your patients think about you.
            </p>
        </div>
    </div>

    <a asp-action="Index" class="btn-dashboard">
        <i class="fas fa-arrow-left"></i>
        Back
    </a>
</div>

<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-label">
            Average Rating
        </div>

        <div class="stat-number text-warning">
            ⭐ @Model.AverageRate.ToString("0.0")
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-label">
            Total Reviews
        </div>

        <div class="stat-number">
            @Model.TotalReviews
        </div>
    </div>

</div>

@if (!Model.Reviews.Any())
{
    <div class="dash-card text-center">

        <i class="fas fa-comment-slash empty-icon"></i>

        <h3>No Reviews Yet</h3>

        <p class="text-muted">
            You don't have any reviews yet.
        </p>

    </div>
}
else
{
    <div class="reviews-grid">

        @foreach (var review in Model.Reviews)
        {
            <div class="review-card">

                <div class="review-header">

                    <div>
                        <h5>@review.PatientName</h5>

                        <span class="review-date">
                            @review.CreatedAt.ToString("dd MMM yyyy")
                        </span>
                    </div>

                    <div class="review-rate">

                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= review.Rate)
                            {
                                <i class="fas fa-star"></i>
                            }
                            else
                            {
                                <i class="far fa-star"></i>
                            }
                        }

                    </div>

                </div>

                <div class="review-comment">

                    @if (string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <span class="text-muted">
                            No comment provided.
                        </span>
                    }
                    else
                    {
                        @review.Comment
                    }

                </div>

            </div>
        }

    </div>
}

<style>

    .reviews-grid {
        display: grid;
        gap: 22px;
        margin-top: 25px;
    }

    .review-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid #edf0f5;
        box-shadow: 0 10px 25px rgba(0,0,0,.05);
        transition: .25s;
    }

        .review-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 35px rgba(0,0,0,.08);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 18px;
    }

        .review-header h5 {
            margin: 0;
            font-size: 18px;
            font-weight: 700;
        }

    .review-date {
        color: #8b8b8b;
        font-size: 13px;
    }

    .review-rate {
        color: #ffc107;
        font-size: 20px;
        letter-spacing: 2px;
    }

    .review-comment {
        background: #f8f9fc;
        border-left: 4px solid #14b8a6;
        padding: 18px;
        border-radius: 12px;
        line-height: 1.8;
        color: #444;
    }

    .empty-icon {
        font-size: 60px;
        color: #d6d6d6;
        margin-bottom: 18px;
    }

</style>