@model Midix.ViewModel.PatientHeaderInfo
@{
    var active = ViewData["ActiveTab"]?.ToString() ?? "overview";
}
<aside class="sidebar patient-sidebar">
    <div class="sidebar-brand">
        <div class="logo-icon small blue-icon"><i class="fas fa-heartbeat"></i></div>
        <span>Patient Portal</span>
    </div>
    <div class="sidebar-user">

        @if (!string.IsNullOrEmpty(Model.PictureUrl))
        {
            <img src="@Model.PictureUrl" class="sidebar-profile-img" />
        }
        else
        {
            <div class="user-avatar blue-avatar">
                @Model.Initials
            </div>
        }

        <div class="user-info">
            <div class="user-name">
                @Model.FirstName @Model.LastName
            </div>

            <div class="user-email">
                @Model.Email
            </div>
        </div>

    </div>

    <nav class="sidebar-nav">
        <a asp-controller="Home" asp-action="Index" class="sidebar-link">
            <i class="fas fa-home"></i> Home
        </a>
        <a asp-controller="PatientDashboard" asp-action="Index"
           class="sidebar-link @(active == "overview" ? "active" : "")">
            <i class="fas fa-chart-pie"></i> Overview
        </a>
        <a asp-controller="PatientDashboard" asp-action="BookAppointment"
           class="sidebar-link @(active == "book" ? "active" : "")">
            <i class="fas fa-calendar-plus"></i> Book Appointment
        </a>
        <a asp-controller="PatientDashboard" asp-action="Appointments"
           class="sidebar-link @(active == "appointments" ? "active" : "")">
            <i class="fas fa-calendar-alt"></i> My Appointments
        </a>
        <a asp-controller="PatientDashboard" asp-action="Prescriptions"
           class="sidebar-link @(active == "prescriptions" ? "active" : "")">
            <i class="fas fa-file-prescription"></i> Prescriptions
        </a>
        <a asp-controller="AiPrescription" asp-action="Index"
           class="sidebar-link @(active == "ai" ? "active" : "")">
            <i class="fas fa-robot"></i> AI Analysis
        </a>
        <a asp-controller="PatientDashboard" asp-action="Profile"
           class="sidebar-link @(active == "profile" ? "active" : "")">
            <i class="fas fa-user"></i> Profile
        </a>
        <a asp-controller="Rating" asp-action="Index"
           class="sidebar-link @(active == "rating" ? "active" : "")">
            <i class="fas fa-star"></i> Rate My Doctor
        </a>
    </nav>

    <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="sidebar-link logout">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>
    </div>
</aside>
<style>



    .sidebar-user {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px;
        margin: 15px 0;
        background: #f8fafc;
        border-radius: 16px;
    }

    .sidebar-profile-img {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #2563eb;
        flex-shrink: 0;
    }

    .user-avatar {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 700;
    }

    .user-info {
        overflow: hidden;
    }

    .user-name {
        font-size: 16px;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 4px;
    }

    .user-email {
        font-size: 13px;
        color: #6b7280;
        overflow: hidden;
        text-overflow: ellipsis;
    }

</style>