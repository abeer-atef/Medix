@model Midix.ViewModel.SubmitRatingVM
@{
    ViewData["Title"] = "Rate Your Doctor";
    ViewData["ActiveTab"] = "rating";
}

<div class="dashboard-layout">

    @* same sidebar as above *@
    @await Component.InvokeAsync("PatientSidebar")

    <main class="dashboard-main">

        <div class="page-header mb-4">
            <h2 class="fw-bold">
                <i class="fas fa-star text-warning me-2"></i> Rate Your Doctor
            </h2>
            <p class="text-muted">Share your experience to help others choose the right doctor</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="card border-0 shadow-sm" style="border-radius:16px;">
                    <div class="card-body p-4 p-md-5">

                        {{-- Doctor info header --}}
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="doctor-avatar-lg">
                                <i class="fas fa-user-md"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0">Dr. @Model.DoctorName</h5>
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    @Model.Specialization
                                </span>
                                <div class="text-muted small mt-1">
                                    <i class="fas fa-calendar-check me-1 text-success"></i>
                                    Completed on @Model.AppointmentDate.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                        </div>

                        <hr class="mb-4" />

                        <form asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="AppointmentId" />
                            <input type="hidden" asp-for="DoctorName" />
                            <input type="hidden" asp-for="Specialization" />
                            <input type="hidden" asp-for="AppointmentDate" />

                            {{-- Star Rating --}}
                            <div class="mb-4">
                                <label class="form-label fw-semibold">
                                    Your Rating <span class="text-danger">*</span>
                                </label>
                                <div class="star-picker" id="starPicker">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star star-btn @(i <= Model.Rate ? "active" : "")"
                                           data-value="@i"></i>
                                    }
                                </div>
                                <input type="hidden" asp-for="Rate" id="rateInput" />
                                <span asp-validation-for="Rate" class="text-danger small"></span>
                            </div>

                            {{-- Comment --}}
                            <div class="mb-4">
                                <label asp-for="Comment" class="form-label fw-semibold">
                                    Your Comment <span class="text-muted fw-normal">(optional)</span>
                                </label>
                                <textarea asp-for="Comment"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Tell others about your experience with this doctor…"
                                          style="border-radius:10px; resize:none;"></textarea>
                                <span asp-validation-for="Comment" class="text-danger small"></span>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-warning fw-bold flex-grow-1">
                                    <i class="fas fa-paper-plane me-1"></i> Submit Rating
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary">
                                    Cancel
                                </a>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const stars = document.querySelectorAll('.star-btn');
        const rateInput = document.getElementById('rateInput');

        function setStars(val) {
            stars.forEach(s => {
                s.classList.toggle('active', parseInt(s.dataset.value) <= val);
            });
            rateInput.value = val;
        }

        stars.forEach(star => {
            star.addEventListener('click', () => setStars(parseInt(star.dataset.value)));
            star.addEventListener('mouseover', () => {
                stars.forEach(s =>
                    s.classList.toggle('hover', parseInt(s.dataset.value) <= parseInt(star.dataset.value))
                );
            });
            star.addEventListener('mouseout', () => {
                stars.forEach(s => s.classList.remove('hover'));
            });
        });
    </script>
}

<style>
    .doctor-avatar-lg {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #60a5fa);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 28px;
        flex-shrink: 0;
    }

    .star-picker {
        display: flex;
        gap: 8px;
        margin-bottom: 6px;
    }

    .star-btn {
        font-size: 32px;
        color: #d1d5db;
        cursor: pointer;
        transition: color 0.15s, transform 0.1s;
    }

        .star-btn.active, .star-btn.hover {
            color: #f59e0b;
        }

        .star-btn:hover {
            transform: scale(1.15);
        }
</style>