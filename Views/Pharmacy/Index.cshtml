@{
    ViewData["Title"] = "Nearby Pharmacies";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="~/css/pharmacy.css" />
<style>
    nav {
        display: none;
    }
</style>
<section class="pharmacy-hero">
    <a class="back-link" asp-controller="Home" asp-action="Index">&larr; Back</a>
    <h1>Nearby Pharmacies</h1>
    <p>Find pharmacies close to your current location</p>
</section>

<div class="pharmacy-layout">
    <aside class="pharmacy-sidebar">
        <input type="text" id="pharmacySearch" class="pharmacy-search" placeholder="Search pharmacies..." />

        <button type="button" id="detectLocationBtn" class="pharmacy-detect-btn">
            <span>&#8853;</span> Detect My Location
        </button>

        @* Populated entirely by pharmacy-page.js via the Overpass API *@
        <div id="pharmacyList">
            <p class="pharmacy-empty">Detecting your location to find nearby pharmacies...</p>
        </div>
    </aside>

    <div id="pharmacyMap"></div>
</div>


@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/pharmacy.js"></script>
    <script src="~/js/pharmacy-page.js"></script>
}
