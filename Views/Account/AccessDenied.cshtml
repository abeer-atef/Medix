@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section" style="text-align:center; padding: 6rem 1rem;">
    <i class="fas fa-lock" style="font-size: 3rem; color: var(--red, #e53e3e); margin-bottom: 1rem;"></i>
    <h1 style="margin-bottom: .5rem;">Access Denied</h1>
    <p style="color: var(--gray-500); margin-bottom: 2rem;">
        You don't have permission to view this page.
    </p>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
        <i class="fas fa-home"></i> Back to Home
    </a>
</section>
